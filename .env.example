# Токен Telegram-бота
BOT_TOKEN=123456789:replace_with_real_bot_token

# База даних
DATABASE_URL=sqlite:///./bot.db

# Рівень логування
LOG_LEVEL=INFO

# Дані Telegram API для Telethon
TG_API_ID=12345678
TG_API_HASH=replace_with_real_api_hash
TG_SESSION_NAME=robocop_session

# Публічні Telegram-джерела для пошуку згадок номера
TG_PUBLIC_PHONE_SOURCES=@source_one,https://t.me/source_two,@source_three
